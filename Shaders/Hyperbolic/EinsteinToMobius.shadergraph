{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "7a7f4453e0aa402b999a00b42a2db84c",
    "m_Title": "Formula",
    "m_Content": "Due to it keeping lines as lines, the Beltrami-Klein projection will be used for the tiles in real space. However due to its ease of calculation the Poincare Disk will be used for the actual position computation.\nDue to this a conversion between those models is needed.\nThe formula to convert the positions from the Klein model to Poincare Disk model is:\nf(z) = 2z/(1+|z|^2)",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1102.0,
        "y": -392.0,
        "width": 200.0,
        "height": 213.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

